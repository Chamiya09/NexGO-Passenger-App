{
  "expo": {
    "name": "NexGO Passenger",
    "slug": "nexgo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/Passanger App Logo.png",
    "scheme": "nexgo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow NexGO to use your current location for pickup and drop-off selection.",
        "NSPhotoLibraryUsageDescription": "Allow NexGO to access photos so you can choose a profile image."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/Passanger App Logo.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "usesCleartextTraffic": true,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.chamiya09.nexgo"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow NexGO to use your current location for pickup and drop-off selection.",
          "locationAlwaysAndWhenInUsePermission": "Allow NexGO to use your location for rides."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow NexGO to select a profile image from your gallery."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Passanger App Logo.png",
          "imageWidth": 240,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4fcd738-402d-456f-960d-d203e867870d"
      }
    }
    ,
    "splash": {
      "image": "./assets/images/Passanger App Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    }
  }
}
